import rclpy
from rclpy.node import Node
import random

class LandingDetector(Node):
    def __init__(self):
        super().__init__('landing_detector')

        self.height = 10.0
        self.offset_x = 0.0
        self.offset_y = 0.0
        self.pad_visible = False

        self.timer = self.create_timer(1.0, self.landing_check)

        self.declare_parameter('max_height', 1.0)
        self.declare_parameter('max_offset', 0.3)
        self.declare_parameter('descent_rate', 0.5)
        self.declare_parameter('detection_rate', 0.8)

        self.get_logger().info('Precision landing detector started')

    def landing_check(self):
        self.height -= self.get_parameter('descent_rate').value

        if self.height < 0.5:
            self.height = 0.5

        self.pad_visible = random.random() > (1.0 - self.get_parameter('detection_rate').value)

        if self.pad_visible:
            self.offset_x = round((random.random() - 0.5) * 2, 2)
            self.offset_y = round((random.random() - 0.5) * 2, 2)

            self.get_logger().info(
                f'Pad visible | Height: {self.height:.1f} m | Offset X: {self.offset_x} | Offset Y: {self.offset_y}'
            )

            if self.height <= self.get_parameter('max_height').value and abs(self.offset_x) < self.get_parameter('max_offset').value and abs(self.offset_y) < self.get_parameter('max_offset').value:
                self.get_logger().info('Precision landing success')
        else:
            self.get_logger().info(
                f'Searching for pad | Height: {self.height:.1f} m'
            )

def main(args=None):
    rclpy.init(args=args)
    node = LandingDetector()
    rclpy.spin(node)
    node.destroy_node()
    rclpy.shutdown()

if __name__ == '__main__':
    main()
